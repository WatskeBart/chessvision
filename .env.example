# Copy to .env and edit. All values shown are the defaults from settings.py, so
# you only need to keep the lines you actually change. See docs/configuration.md.

# Camera/MJPEG stream URL to read frames from.
GRANDMASTER_STREAM_URL=http://10.42.0.177:4444/stream

# YOLO model for inference. A single file (.pt/.onnx) OR an NCNN export
# directory — point at the folder, not a file inside it.
GRANDMASTER_PIECES_MODEL_PATH=models/pieces_ncnn_model

# Detection method: "diff" (model-free image subtraction) or "model" (YOLO).
GRANDMASTER_DETECTION_MODE=diff

# Draw the detection overlay at startup (toggle live with 'd').
GRANDMASTER_SHOW_DETECTIONS=false

# Min YOLO confidence to accept a detection (model mode / 'v' check).
GRANDMASTER_PIECES_CONF_THRESHOLD=0.3

# Board orientation (square-name mapping only; the view stays raw-feed).
# NOTE: board_rotation CANNOT be set here — its Literal[int] type rejects env
# strings and would crash on startup. Change it in settings.py or cycle with 'o'.
#   GRANDMASTER_BOARD_ROTATION=90   # <-- do not enable; see docs/configuration.md
GRANDMASTER_FLIP_ORIENTATION=false

# Display + warp.
GRANDMASTER_DISPLAY_SIZE=800
GRANDMASTER_WARP_PADDING=40

# Game recording.
GRANDMASTER_GAME_STABILITY_FRAMES=6
GRANDMASTER_GAMES_DIR=games
GRANDMASTER_GAME_DEBUG=false

# "diff" mode tuning (see docs/configuration.md).
GRANDMASTER_DIFF_CHANGE_THRESHOLD=8.0
GRANDMASTER_DIFF_INNER_FRACTION=0.7
GRANDMASTER_DIFF_MAX_CHANGED=6
GRANDMASTER_DIFF_TOLERANCE=1

# Training (gm-train / gm-capture).
GRANDMASTER_TRAIN_MODEL_PATH=models/yolo26n.pt
GRANDMASTER_TRAIN_DATA_YAML=datasets/chess-pieces/data.yaml
GRANDMASTER_TRAIN_EPOCHS=100
GRANDMASTER_TRAIN_IMGSZ=640
GRANDMASTER_TRAIN_PATIENCE=20
GRANDMASTER_TRAIN_DEVICE=0
