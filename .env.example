# Camera/MJPEG stream URL to read frames from.
GRANDMASTER_STREAM_URL=http://10.42.0.177:4444/stream

# Path to a YOLO model fine-tuned on chess pieces (detect_pieces.py inference).
GRANDMASTER_PIECES_MODEL_PATH=models/pieces.pt

# Base checkpoint to fine-tune from (train_pieces.py).
GRANDMASTER_TRAIN_MODEL_PATH=models/yolo26n.pt

# Training dataset + hyperparameters (train_pieces.py).
GRANDMASTER_TRAIN_DATA_YAML=datasets/chess-pieces/data.yaml
GRANDMASTER_TRAIN_EPOCHS=100
GRANDMASTER_TRAIN_IMGSZ=640
GRANDMASTER_TRAIN_PATIENCE=20
GRANDMASTER_TRAIN_DEVICE=0

# Board orientation. Leave false when the warped top-left square is a8 (as seen
# by the camera). Set true when the top-left square is a1 instead, which rotates
# the square labels 180 degrees to match.
GRANDMASTER_FLIP_ORIENTATION=true

# Minimum side length (px) to upscale the displayed board view to.
GRANDMASTER_DISPLAY_SIZE=800

# Minimum confidence for a piece detection to be accepted (0.0–1.0).
# Raise this to suppress false positives on empty squares (e.g. 0.5–0.7).
GRANDMASTER_PIECES_CONF_THRESHOLD=0.4
